<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ANILORE - Plataforma de Manga, Manhwa y Anime</title>
    
    <!-- LIBRERÍAS EXTERNAS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- CONFIGURACIÓN TAILWIND -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#f97316', // orange-500
                        'bg-dark': '#09090b', // zinc-950
                        'card-bg': '#18181b', // zinc-900
                    },
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <!-- FIREBASE SDK -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, onAuthStateChanged, signOut, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";

        let auth;
        try {
            const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {};
            if(Object.keys(firebaseConfig).length > 0) {
                const app = initializeApp(firebaseConfig);
                auth = getAuth(app);
                
                window.firebaseAuth = auth;
                window.createUser = createUserWithEmailAndPassword;
                window.signIn = signInWithEmailAndPassword;
                window.logout = signOut;

                const initAuth = async () => {
                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await signInWithCustomToken(auth, __initial_auth_token);
                    }
                };
                initAuth();

                onAuthStateChanged(auth, (user) => {
                    updateUserUI(user);
                });
            } else {
                console.warn("Firebase no configurado. Ejecutando en modo local.");
                updateUserUI(null);
            }
        } catch (e) {
            console.error("Error inicializando Firebase:", e);
            updateUserUI(null);
        }

        function updateUserUI(user) {
            const userBtn = document.getElementById('user-menu-btn');
            const userNameDisplay = document.getElementById('user-name-nav');
            const navProfile = document.getElementById('nav-profile');
            
            if (user) {
                userBtn.innerHTML = `<i class="fa-solid fa-right-from-bracket text-sm text-white"></i>`;
                userBtn.classList.add('bg-primary', 'border-primary', 'shadow-[0_0_15px_rgba(249,115,22,0.4)]');
                userBtn.onclick = () => window.handleLogout();
                userNameDisplay.innerText = user.email ? user.email.split('@')[0] : "Usuario";
                navProfile.classList.remove('hidden');
                window.closeAuthModal();
            } else {
                userBtn.innerHTML = `<i class="fa-solid fa-user text-sm"></i>`;
                userBtn.classList.remove('bg-primary', 'border-primary', 'shadow-[0_0_15px_rgba(249,115,22,0.4)]');
                userBtn.onclick = () => window.openAuthModal();
                userNameDisplay.innerText = "Invitado";
                navProfile.classList.add('hidden');
                if (window.currentSection === 'profile') window.showSection('home');
            }
        }
    </script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,600;0,800;1,800&display=swap');
        
        body { background-color: #09090b; color: #f4f4f5; margin: 0; overflow-x: hidden; }
        
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #09090b; }
        ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #f97316; }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        
        .glass-nav { background: rgba(9, 9, 11, 0.7); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
        .glass-panel { background: rgba(24, 24, 27, 0.6); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.05); }
        
        .manhwa-card { border-radius: 20px; overflow: hidden; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); background: #18181b; border: 1px solid rgba(255, 255, 255, 0.03); }
        .manhwa-card:hover { transform: translateY(-8px); border-color: #f97316; box-shadow: 0 20px 40px -10px rgba(249, 115, 22, 0.3); }
        .card-gradient { background: linear-gradient(to top, #000000 0%, rgba(0,0,0,0.4) 50%, transparent 100%); }
        
        .alphabet-btn { background: #1f1f23; color: #a1a1aa; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; border-radius: 12px; font-weight: 700; font-size: 13px; transition: all 0.3s ease; cursor: pointer; border: 1px solid transparent; flex-shrink: 0; }
        .alphabet-btn:hover { background: #27272a; border-color: rgba(255,255,255,0.1); }
        .alphabet-btn.active { background: #f97316; color: white; border-color: #f97316; box-shadow: 0 4px 15px rgba(249,115,22,0.3); }
        
        .custom-input { background: #121214; border: 1px solid #27272a; border-radius: 14px; padding: 14px 18px; width: 100%; outline: none; color: white; transition: all 0.3s ease; font-size: 14px; }
        .custom-input:focus { border-color: #f97316; background: #18181b; box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1); }
        
        .hidden-section { display: none !important; }
        
        #auth-modal { background: rgba(0,0,0,0.9); backdrop-filter: blur(15px); }
        .file-drop-area { border: 2px dashed #3f3f46; border-radius: 20px; min-height: 160px; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; position: relative; overflow: hidden; transition: all 0.3s ease; background: rgba(255,255,255,0.01); }
        .file-drop-area:hover, .file-drop-area.dragover { border-color: #f97316; background: rgba(249, 115, 22, 0.05); }
        .preview-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 5; }
        
        #custom-toast { position: fixed; bottom: 30px; right: 30px; background: #18181b; border: 1px solid #27272a; color: white; padding: 16px 24px; border-radius: 16px; font-weight: 600; z-index: 1000; transform: translateY(150px) scale(0.9); opacity: 0; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; items-center; gap: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.5); }
        #custom-toast.show { transform: translateY(0) scale(1); opacity: 1; }
        
        .animate-fade-in { animation: fadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards; opacity: 0; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        
        .chapter-item { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease; }
        .chapter-item:hover { background: #f97316; border-color: #f97316; transform: translateX(8px); box-shadow: 0 10px 20px rgba(249,115,22,0.2); }
        .tab-btn { color: #71717a; border-bottom: 2px solid transparent; }
        .tab-btn:hover { color: #e4e4e7; }
        .tab-btn.active { border-bottom-color: #f97316; color: white; text-shadow: 0 0 10px rgba(249,115,22,0.5); }

        .btn-action { transition: all 0.3s; }
        .btn-action.active { background: #f97316; color: white; border-color: #f97316; box-shadow: 0 8px 20px rgba(249,115,22,0.3); }
        
        .hero-glow { position: absolute; width: 300px; height: 300px; background: #f97316; filter: blur(150px); opacity: 0.2; border-radius: 50%; z-index: 0; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; }
        
        /* Video Player Custom */
        .video-container { position: relative; width: 100%; aspect-ratio: 16/9; background: black; border-radius: 12px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); }
        video { width: 100%; height: 100%; object-fit: contain; }
    </style>
</head>
<body class="antialiased selection:bg-primary selection:text-white">

    <!-- NOTIFICACIONES -->
    <div id="custom-toast">
        <div id="toast-icon" class="w-8 h-8 rounded-full bg-primary/20 text-primary flex items-center justify-center"><i class="fa-solid fa-check"></i></div>
        <span id="toast-msg">Acción completada</span>
    </div>

    <!-- MODAL DE AUTENTICACIÓN -->
    <div id="auth-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-6 opacity-0 transition-opacity duration-300">
        <div class="bg-[#121214] w-full max-w-md rounded-[32px] border border-zinc-800 p-8 relative overflow-hidden shadow-2xl transform scale-95 transition-transform duration-300" id="auth-modal-content">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-orange-600 to-orange-400"></div>
            <button onclick="closeAuthModal()" class="absolute top-6 right-6 text-zinc-500 hover:text-white hover:rotate-90 transition duration-300">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
            <div id="auth-login-view" class="animate-fade-in">
                <h2 class="text-3xl font-black uppercase mb-1">Bienvenido</h2>
                <p class="text-zinc-500 text-sm mb-8">Inicia sesión para guardar tus obras favoritas.</p>
                <div class="space-y-4">
                    <div class="relative">
                        <i class="fa-solid fa-envelope absolute left-4 top-4 text-zinc-500"></i>
                        <input type="email" id="login-email" placeholder="Correo electrónico" class="custom-input pl-11">
                    </div>
                    <div class="relative">
                        <i class="fa-solid fa-lock absolute left-4 top-4 text-zinc-500"></i>
                        <input type="password" id="login-pass" placeholder="Contraseña" class="custom-input pl-11">
                    </div>
                    <button onclick="handleLoginAction()" class="w-full bg-primary hover:bg-orange-600 py-4 rounded-xl font-black uppercase text-sm text-white transition-all shadow-[0_10px_20px_rgba(249,115,22,0.3)] hover:shadow-[0_15px_25px_rgba(249,115,22,0.4)] hover:-translate-y-1 mt-2">Iniciar Sesión</button>
                    <p class="text-center text-sm text-zinc-500 mt-6">¿No tienes cuenta? <button onclick="toggleAuthView('signup')" class="text-primary hover:text-orange-400 font-bold transition">Regístrate</button></p>
                </div>
            </div>
            <div id="auth-signup-view" class="hidden animate-fade-in">
                <h2 class="text-3xl font-black uppercase mb-1">Únete</h2>
                <p class="text-zinc-500 text-sm mb-8">Crea tu cuenta en Anilore.</p>
                <div class="space-y-4">
                    <div class="relative">
                        <i class="fa-solid fa-user absolute left-4 top-4 text-zinc-500"></i>
                        <input type="text" id="signup-user" placeholder="Nombre de usuario" class="custom-input pl-11">
                    </div>
                    <div class="relative">
                        <i class="fa-solid fa-envelope absolute left-4 top-4 text-zinc-500"></i>
                        <input type="email" id="signup-email" placeholder="Correo electrónico" class="custom-input pl-11">
                    </div>
                    <div class="relative">
                        <i class="fa-solid fa-lock absolute left-4 top-4 text-zinc-500"></i>
                        <input type="password" id="signup-pass" placeholder="Contraseña" class="custom-input pl-11">
                    </div>
                    <button onclick="handleSignupAction()" class="w-full bg-white text-black hover:bg-primary hover:text-white py-4 rounded-xl font-black uppercase text-sm transition-all shadow-lg hover:shadow-[0_10px_20px_rgba(249,115,22,0.3)] hover:-translate-y-1 mt-2">Crear Cuenta</button>
                    <p class="text-center text-sm text-zinc-500 mt-6">¿Ya tienes cuenta? <button onclick="toggleAuthView('login')" class="text-primary hover:text-orange-400 font-bold transition">Inicia Sesión</button></p>
                </div>
            </div>
        </div>
    </div>

    <!-- NAVEGACIÓN -->
    <nav class="glass-nav fixed w-full top-0 z-50 px-6 py-3 flex justify-between items-center transition-all duration-300">
        <div class="flex items-center gap-3 cursor-pointer group" onclick="showSection('home')">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-400 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/30 group-hover:rotate-12 transition duration-300">
                <i class="fa-solid fa-play text-white text-xl"></i>
            </div>
            <div class="hidden sm:block leading-none">
                <span class="text-2xl font-black tracking-tighter text-white">ANILORE</span>
                <p class="text-[9px] text-primary font-bold uppercase tracking-widest mt-0.5">Anime & Manga</p>
            </div>
        </div>

        <div class="hidden md:flex gap-8 font-bold text-zinc-400 text-xs uppercase tracking-widest bg-[#18181b]/80 px-8 py-3 rounded-full border border-zinc-800/50">
            <button id="nav-home" onclick="showSection('home')" class="text-primary transition hover:text-orange-400">Inicio</button>
            <button id="nav-library" onclick="showSection('library')" class="hover:text-primary transition">Biblioteca</button>
            <button id="nav-upload" onclick="showSection('upload')" class="hover:text-primary transition">Publicar</button>
            <button id="nav-profile" onclick="showSection('profile')" class="hover:text-primary transition hidden">Mi Perfil</button>
        </div>

        <div class="flex items-center gap-4">
            <div class="relative hidden sm:block group">
                <input type="text" id="main-search" oninput="handleSearch(this.value)" placeholder="Buscar obra..." class="bg-zinc-900/80 border border-zinc-800 rounded-full pl-10 pr-5 py-2.5 text-sm focus:outline-none w-44 focus:w-72 transition-all duration-300 text-white focus:border-primary focus:bg-[#121214] placeholder-zinc-600">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-3.5 text-zinc-500 text-xs group-focus-within:text-primary transition"></i>
            </div>
            <div class="flex items-center gap-3 ml-1">
                <span id="user-name-nav" class="hidden lg:block text-[11px] font-bold uppercase text-zinc-400 tracking-wider">Invitado</span>
                <button id="user-menu-btn" onclick="openAuthModal()" class="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center border border-zinc-800 hover:border-primary transition duration-300 hover:text-primary">
                    <i class="fa-solid fa-user text-sm"></i>
                </button>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="min-h-screen">
        
        <!-- INICIO -->
        <div id="home-section" class="pt-28 pb-32 md:pb-20 px-6 md:px-12 max-w-[1600px] mx-auto animate-fade-in relative">
            <div class="hero-glow"></div>
            <div id="hero-container" class="relative h-[450px] rounded-[32px] overflow-hidden shadow-2xl group cursor-pointer border border-zinc-800/50" onclick="openHeroDetails()">
                <img id="hero-bg" src="https://images.unsplash.com/photo-1618336753974-aae8e04506aa?q=80&w=2070" class="absolute inset-0 w-full h-full object-cover transition-transform duration-[20s] group-hover:scale-110">
                <div class="absolute inset-0 bg-gradient-to-t from-[#09090b] via-[#09090b]/50 to-transparent"></div>
                <div class="relative z-10 h-full flex flex-col justify-end p-8 md:p-14 max-w-3xl">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="bg-primary text-white text-[10px] font-black px-4 py-1.5 rounded-full uppercase tracking-widest shadow-lg">Destacado</span>
                    </div>
                    <h1 id="hero-title" class="text-5xl md:text-7xl font-black italic uppercase text-white mb-4 group-hover:text-primary transition-colors">Solo Leveling</h1>
                    <p id="hero-desc" class="text-zinc-300 text-sm md:text-base line-clamp-3 max-w-2xl font-light">Descubre la obra maestra que redefinió el género de acción.</p>
                    <div class="mt-8">
                        <button class="bg-white text-black px-8 py-3.5 rounded-xl font-bold uppercase text-xs tracking-widest hover:bg-primary hover:text-white transition-all flex items-center gap-2">
                            <i class="fa-solid fa-play"></i> Ver Ahora
                        </button>
                    </div>
                </div>
            </div>

            <h2 id="home-title" class="text-2xl font-black uppercase mb-8 mt-16 flex items-center gap-3">
                <span class="w-8 h-1.5 bg-primary rounded-full"></span> Últimas Novedades
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-6 gap-5 md:gap-8" id="home-grid"></div>
        </div>

        <!-- BIBLIOTECA -->
        <div id="library-section" class="pt-28 px-6 md:px-12 pb-32 hidden-section max-w-[1600px] mx-auto animate-fade-in">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-6">
                <div>
                    <h1 class="text-4xl font-black uppercase text-white mb-2 tracking-tighter">Directorio</h1>
                    <div class="flex gap-4 mt-2">
                        <button onclick="filterType('All')" class="text-xs font-bold uppercase tracking-widest text-primary border-b-2 border-primary pb-1">Todo</button>
                        <button onclick="filterType('Manga')" class="text-xs font-bold uppercase tracking-widest text-zinc-500 hover:text-white transition">Manga</button>
                        <button onclick="filterType('Anime')" class="text-xs font-bold uppercase tracking-widest text-zinc-500 hover:text-white transition">Anime</button>
                    </div>
                </div>
                <div class="flex flex-wrap gap-2 bg-[#121214] p-2 rounded-2xl border border-zinc-800 shadow-inner">
                    <button class="alphabet-btn active" id="alpha-all" onclick="filterByLetter('#')">#</button>
                    <script>
                        "ABCDEFGHIJKLMNÑOPQRSTUVWXYZ".split("").forEach(l => {
                            document.write(`<button class="alphabet-btn" onclick="filterByLetter('${l}')">${l}</button>`);
                        });
                    </script>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-6 gap-5 md:gap-8" id="library-grid"></div>
        </div>

        <!-- PERFIL -->
        <div id="profile-section" class="pt-28 px-6 md:px-12 pb-32 hidden-section max-w-[1600px] mx-auto animate-fade-in">
            <div class="glass-panel p-8 md:p-12 rounded-[32px] mb-12 flex flex-col md:flex-row items-center gap-8">
                <div class="w-32 h-32 rounded-full bg-zinc-800 border-4 border-zinc-700 overflow-hidden">
                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" class="w-full h-full object-cover">
                </div>
                <div class="text-center md:text-left">
                    <h1 id="profile-name" class="text-4xl font-black uppercase tracking-tighter">Usuario</h1>
                    <div class="flex gap-6 mt-6">
                        <div class="text-center"><p class="text-2xl font-black" id="stat-like">0</p><p class="text-[10px] text-zinc-500 font-bold uppercase">Favoritos</p></div>
                        <div class="text-center"><p class="text-2xl font-black" id="stat-save">0</p><p class="text-[10px] text-zinc-500 font-bold uppercase">Guardados</p></div>
                        <div class="text-center"><p class="text-2xl font-black text-primary" id="stat-done">0</p><p class="text-[10px] text-zinc-500 font-bold uppercase">Terminados</p></div>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-6 gap-5 md:gap-8" id="profile-grid"></div>
        </div>

        <!-- DETALLES -->
        <div id="details-section" class="pt-24 px-6 md:px-12 pb-32 hidden-section max-w-[1400px] mx-auto animate-fade-in relative">
            <button onclick="goBackFromDetails()" class="mb-8 flex items-center gap-2 text-zinc-400 hover:text-white transition font-bold uppercase text-xs bg-zinc-900/50 px-4 py-2 rounded-full backdrop-blur border border-zinc-800">
                <i class="fa-solid fa-arrow-left"></i> Volver
            </button>
            <div class="flex flex-col lg:flex-row gap-12">
                <div class="lg:w-2/3 flex flex-col md:flex-row gap-8">
                    <img id="det-img" src="" class="w-full md:w-72 h-[450px] object-cover rounded-[24px] shadow-2xl border border-zinc-800">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-4">
                            <span id="det-format" class="bg-primary/20 text-primary font-black text-[10px] px-3 py-1 rounded-md border border-primary/30 uppercase tracking-widest">Formato</span>
                            <span id="det-tag" class="text-zinc-400 font-bold text-xs uppercase tracking-widest bg-zinc-800/50 px-3 py-1 rounded-md">Género</span>
                        </div>
                        <h1 id="det-title" class="text-4xl md:text-5xl lg:text-6xl font-black uppercase text-white leading-tight mb-6">Título</h1>
                        <p id="det-sinopsis" class="text-zinc-400 leading-relaxed text-sm md:text-base font-light mb-8">Sinopsis...</p>
                        <div class="flex flex-wrap gap-3">
                            <button onclick="startReading()" id="det-main-btn" class="flex-1 md:flex-none flex justify-center items-center gap-2 px-8 py-3.5 rounded-xl bg-white text-black hover:bg-primary hover:text-white transition-all font-black text-xs uppercase tracking-widest">
                                <i class="fa-solid fa-book-open"></i> Empezar
                            </button>
                            <button id="btn-like" onclick="userAction('like')" class="btn-action w-14 h-[48px] rounded-xl bg-[#121214] border border-zinc-800 text-zinc-400 flex items-center justify-center">
                                <i class="fa-solid fa-heart text-lg"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="lg:w-1/3">
                    <div class="glass-panel p-6 rounded-[24px]">
                        <h3 class="text-lg font-black uppercase mb-4 flex items-center gap-2" id="det-list-title">
                            <i class="fa-solid fa-list-ul text-primary"></i> Capítulos
                        </h3>
                        <div id="det-episodes" class="space-y-2 overflow-y-auto max-h-[500px] scrollbar-hide"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PUBLICAR -->
        <div id="upload-section" class="pt-28 px-6 md:px-12 pb-32 hidden-section max-w-[1000px] mx-auto animate-fade-in">
            <div class="text-center mb-10">
                <h1 class="text-4xl font-black uppercase mb-2">Panel de Creador</h1>
                <p class="text-zinc-500">Publica anime o manga para la comunidad.</p>
            </div>
            <div class="flex justify-center gap-2 mb-8 bg-[#121214] p-1.5 rounded-2xl border border-zinc-800 max-w-md mx-auto">
                <button onclick="switchUploadTab('obra')" id="tab-obra" class="alphabet-btn !w-1/2 !h-12 active !rounded-xl">Nueva Obra</button>
                <button onclick="switchUploadTab('capitulo')" id="tab-capitulo" class="alphabet-btn !w-1/2 !h-12 !rounded-xl">Subir Contenido</button>
            </div>

            <!-- Nueva Obra Form -->
            <div id="form-obra" class="glass-panel p-8 rounded-[32px] shadow-2xl border-l-4 border-primary">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2"><i class="fa-solid fa-circle-plus text-primary"></i> Datos Generales</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="file-drop-area h-[220px]" onclick="document.getElementById('in-portada').click()">
                        <input type="file" id="in-portada" hidden accept="image/*" onchange="previewImg(this, 'pre-portada', 'ico-portada')">
                        <img id="pre-portada" class="preview-img hidden rounded-xl">
                        <div id="ico-portada" class="text-center flex flex-col items-center">
                            <i class="fa-solid fa-image text-2xl text-zinc-500 mb-2"></i>
                            <p class="text-[10px] font-bold uppercase text-zinc-400">Portada</p>
                        </div>
                    </div>
                    <div class="md:col-span-2 space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="col-span-2 sm:col-span-1">
                                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Título</label>
                                <input type="text" id="obra-titulo" placeholder="Ej: Dragon Ball Z" class="custom-input">
                            </div>
                            <div class="col-span-2 sm:col-span-1">
                                <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Formato</label>
                                <select id="obra-formato" class="custom-input">
                                    <option value="Manga">📖 Manga / Manhwa</option>
                                    <option value="Anime">📺 Anime / Serie</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Género</label>
                            <select id="obra-genero" class="custom-input">
                                <option value="Acción">Acción</option>
                                <option value="Fantasía">Fantasía</option>
                                <option value="Romance">Romance</option>
                                <option value="Comedia">Comedia</option>
                                <option value="Horror">Horror</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="mt-6">
                    <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Sinopsis</label>
                    <textarea id="obra-sinopsis" class="custom-input h-32" placeholder="Describe la historia..."></textarea>
                </div>
                <button onclick="handlePublicarObra()" class="w-full bg-primary py-4 rounded-xl font-black uppercase text-sm text-white mt-8 shadow-lg">Crear Obra</button>
            </div>

            <!-- Subir Capítulo Form -->
            <div id="form-capitulo" class="glass-panel p-8 rounded-[32px] hidden border-l-4 border-blue-500">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2"><i class="fa-solid fa-cloud-arrow-up text-blue-500"></i> Publicar Episodio</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
                    <div>
                        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Obra</label>
                        <select id="cap-obra-select" onchange="toggleCapInputType(this.value)" class="custom-input"><option value="">Elegir...</option></select>
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Número de Cap/Ep</label>
                        <input type="number" id="cap-numero" placeholder="Ej: 1" class="custom-input">
                    </div>
                </div>

                <!-- Input para Manga -->
                <div id="input-manga-files" class="space-y-2">
                    <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Páginas (Imágenes)</label>
                    <div class="file-drop-area h-[160px]" onclick="document.getElementById('in-paginas').click()">
                        <input type="file" id="in-paginas" hidden multiple accept="image/*" onchange="updateFilesCount(this)">
                        <i class="fa-solid fa-images text-2xl text-zinc-500 mb-2"></i>
                        <p id="paginas-status" class="text-xs font-bold text-zinc-400">Seleccionar imágenes del manga</p>
                    </div>
                </div>

                <!-- Input para Anime -->
                <div id="input-anime-video" class="space-y-2 hidden">
                    <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Fuente del Video (URL o Archivo)</label>
                    <input type="text" id="cap-video-url" placeholder="https://ejemplo.com/video.mp4" class="custom-input mb-3">
                    <div class="file-drop-area h-[120px]" onclick="document.getElementById('in-video').click()">
                        <input type="file" id="in-video" hidden accept="video/*" onchange="updateVideoName(this)">
                        <i class="fa-solid fa-video text-2xl text-zinc-500 mb-2"></i>
                        <p id="video-status" class="text-xs font-bold text-zinc-400">O sube archivo MP4/MKV</p>
                    </div>
                </div>
                
                <button onclick="handleSubirCapitulo()" class="w-full bg-blue-600 py-4 rounded-xl font-black uppercase text-sm text-white mt-8">Publicar Contenido</button>
            </div>
        </div>

        <!-- LECTOR / REPRODUCTOR -->
        <div id="reader-section" class="pt-20 hidden-section bg-black min-h-screen">
            <div class="fixed top-0 left-0 w-full bg-zinc-900/90 backdrop-blur border-b border-zinc-800 p-3 flex justify-between items-center z-50">
                <button onclick="showSection('details')" class="w-10 h-10 rounded-full flex items-center justify-center text-zinc-400 hover:text-white"><i class="fa-solid fa-arrow-left"></i></button>
                <div class="text-center">
                    <h2 id="reader-title" class="text-[10px] font-bold text-primary uppercase">Obra</h2>
                    <h1 id="reader-chap-num" class="text-sm font-black text-white">Cargando...</h1>
                </div>
                <button onclick="toggleReaderSettings()" class="w-10 h-10 rounded-full flex items-center justify-center text-zinc-400 hover:text-white"><i class="fa-solid fa-gear"></i></button>
            </div>

            <!-- Contenedor Manga -->
            <div id="manga-viewer" class="max-w-[800px] mx-auto pt-10 hidden">
                <div id="reader-images" class="flex flex-col items-center w-full"></div>
            </div>

            <!-- Contenedor Anime -->
            <div id="anime-viewer" class="max-w-[1100px] mx-auto pt-16 px-4 hidden">
                <div class="video-container">
                    <video id="main-video-player" controls preload="metadata"></video>
                </div>
            </div>

            <!-- Navegación -->
            <div class="flex justify-between items-center gap-3 mt-16 px-4 max-w-md mx-auto pb-10">
                <button id="btn-prev-bot" onclick="navigateChap(-1)" class="flex-1 bg-zinc-900 py-3.5 rounded-xl font-bold text-xs uppercase border border-zinc-800 text-zinc-400">Ant</button>
                <button onclick="showSection('details')" class="w-14 h-14 bg-zinc-800 rounded-full flex items-center justify-center"><i class="fa-solid fa-list"></i></button>
                <button id="btn-next-bot" onclick="navigateChap(1)" class="flex-1 bg-zinc-900 py-3.5 rounded-xl font-bold text-xs uppercase border border-zinc-800 text-zinc-400">Sig</button>
            </div>
        </div>

    </main>

    <script>
        // --- BASE DE DATOS MOCK ---
        const mockImg = (s) => `https://images.unsplash.com/photo-${s}?q=80&w=600`;
        window.manhwas = [
            { 
                title: "Solo Leveling", 
                format: "Manga", 
                tag: "Acción", 
                numCh: 179, 
                img: mockImg("1618336753974-aae8e04506aa"), 
                sinopsis: "El cazador más débil de la humanidad despierta un poder ilimitado.", 
                chapters: [{num: 1, pages: [mockImg("1555680202-c86f0e12f086")]}] 
            },
            { 
                title: "Demon Slayer", 
                format: "Anime", 
                tag: "Aventura", 
                numCh: 26, 
                img: mockImg("1612438214708-f80e9803dfba"), 
                sinopsis: "Tanjiro busca una cura para su hermana convertida en demonio.", 
                chapters: [{num: 1, video: "https://vjs.zencdn.net/v/oceans.mp4"}] 
            }
        ];
        
        window.userData = { like: [], save: [], done: [] };
        window.currentSection = 'home';
        window.activeWorkIndex = -1;
        window.currentReadChapter = -1;

        // --- FUNCIONES CORE ---
        window.showToast = function(msg, success = true) {
            const t = document.getElementById('custom-toast');
            document.getElementById('toast-msg').innerText = msg;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3000);
        };

        window.showSection = function(id) {
            window.currentSection = id;
            document.querySelectorAll('main > div').forEach(s => s.classList.add('hidden-section'));
            document.getElementById(id + '-section').classList.remove('hidden-section');
            
            if(id === 'home') window.render('home-grid', window.manhwas.slice(0, 6));
            if(id === 'library') window.render('library-grid', window.manhwas);
            if(id === 'upload') window.updateObraSelect();
            if(id === 'profile') window.filterProfile('like');

            // Parar video si se sale del lector
            if(id !== 'reader') {
                const v = document.getElementById('main-video-player');
                v.pause();
                v.src = "";
            }
            window.scrollTo(0,0);
        };

        window.render = function(id, list) {
            const el = document.getElementById(id);
            if(!el) return;
            el.innerHTML = list.map((m, idx) => {
                const realIdx = window.manhwas.findIndex(i => i.title === m.title);
                const formatIcon = m.format === 'Anime' ? 'fa-play-circle' : 'fa-book-open';
                return `
                <div class="manhwa-card group cursor-pointer animate-fade-in" onclick="openDetails(${realIdx})">
                    <div class="aspect-[3/4.2] relative">
                        <img src="${m.img}" class="w-full h-full object-cover transition duration-700 group-hover:scale-110">
                        <div class="absolute inset-0 card-gradient"></div>
                        <div class="absolute top-3 left-3 bg-primary text-white text-[9px] font-black px-2 py-1 rounded border border-white/20 uppercase tracking-widest flex items-center gap-1">
                            <i class="fa-solid ${formatIcon}"></i> ${m.format}
                        </div>
                        <div class="absolute bottom-4 left-4 right-4">
                            <span class="text-[9px] font-black text-primary uppercase tracking-widest mb-1 block">${m.tag}</span>
                            <h3 class="font-black text-white text-sm group-hover:text-primary transition-colors line-clamp-2">${m.title}</h3>
                        </div>
                    </div>
                </div>`;
            }).join('');
        };

        // --- DETALLES ---
        window.openDetails = function(index) {
            window.activeWorkIndex = index;
            const obra = window.manhwas[index];
            document.getElementById('det-img').src = obra.img;
            document.getElementById('det-title').innerText = obra.title;
            document.getElementById('det-tag').innerText = obra.tag;
            document.getElementById('det-format').innerText = obra.format;
            document.getElementById('det-sinopsis').innerText = obra.sinopsis;
            document.getElementById('det-list-title').innerHTML = `<i class="fa-solid ${obra.format === 'Anime' ? 'fa-clapperboard' : 'fa-list-ul'} text-primary"></i> ${obra.format === 'Anime' ? 'Episodios' : 'Capítulos'}`;
            document.getElementById('det-main-btn').innerHTML = `<i class="fa-solid ${obra.format === 'Anime' ? 'fa-play' : 'fa-book-open'}"></i> ${obra.format === 'Anime' ? 'Ver Ep. 1' : 'Leer Cap. 1'}`;

            const epContainer = document.getElementById('det-episodes');
            if(obra.chapters && obra.chapters.length > 0) {
                epContainer.innerHTML = obra.chapters.map(ch => `
                    <div onclick="openReader(${index}, ${ch.num})" class="chapter-item flex justify-between items-center p-4 rounded-xl cursor-pointer group">
                        <span class="font-bold text-sm text-zinc-300 group-hover:text-white">${obra.format === 'Anime' ? 'Episodio' : 'Capítulo'} ${ch.num}</span>
                        <i class="fa-solid fa-play text-xs opacity-0 group-hover:opacity-100 transition"></i>
                    </div>
                `).join('');
            } else {
                epContainer.innerHTML = '<p class="text-zinc-600 text-center py-10 text-xs font-bold uppercase">Próximamente...</p>';
            }
            window.showSection('details');
        };

        // --- LECTOR / VIDEO ---
        window.openReader = function(workIdx, chNum) {
            window.activeWorkIndex = workIdx;
            window.currentReadChapter = chNum;
            const obra = window.manhwas[workIdx];
            const ch = obra.chapters.find(c => c.num === chNum);
            
            document.getElementById('reader-title').innerText = obra.title;
            document.getElementById('reader-chap-num').innerText = `${obra.format === 'Anime' ? 'Episodio' : 'Capítulo'} ${chNum}`;

            const mangaV = document.getElementById('manga-viewer');
            const animeV = document.getElementById('anime-viewer');
            const player = document.getElementById('main-video-player');
            
            if(obra.format === 'Anime') {
                mangaV.classList.add('hidden');
                animeV.classList.remove('hidden');
                player.src = ch.video || "";
                player.play().catch(e => console.log("Auto-play blocked"));
            } else {
                animeV.classList.add('hidden');
                mangaV.classList.remove('hidden');
                document.getElementById('reader-images').innerHTML = (ch.pages || []).map(p => `<img src="${p}" class="w-full mb-1">`).join('');
            }

            const btnPrev = document.getElementById('btn-prev-bot');
            const btnNext = document.getElementById('btn-next-bot');
            btnPrev.disabled = !obra.chapters.find(c => c.num === chNum - 1);
            btnNext.disabled = !obra.chapters.find(c => c.num === chNum + 1);

            window.showSection('reader');
        };

        window.navigateChap = function(dir) {
            window.openReader(window.activeWorkIndex, window.currentReadChapter + dir);
        };

        // --- PANEL CREADOR ---
        window.switchUploadTab = function(tab) {
            document.getElementById('tab-obra').classList.toggle('active', tab === 'obra');
            document.getElementById('tab-capitulo').classList.toggle('active', tab === 'capitulo');
            document.getElementById('form-obra').classList.toggle('hidden', tab === 'capitulo');
            document.getElementById('form-capitulo').classList.toggle('hidden', tab === 'obra');
        };

        window.toggleCapInputType = function(val) {
            if(val === "") return;
            const obra = window.manhwas[val];
            const isAnime = obra.format === 'Anime';
            document.getElementById('input-manga-files').classList.toggle('hidden', isAnime);
            document.getElementById('input-anime-video').classList.toggle('hidden', !isAnime);
        };

        window.updateObraSelect = function() {
            const s = document.getElementById('cap-obra-select');
            s.innerHTML = '<option value="">Elegir...</option>' + window.manhwas.map((m, i) => `<option value="${i}">${m.title} (${m.format})</option>`).join('');
        };

        window.handlePublicarObra = function() {
            const t = document.getElementById('obra-titulo').value;
            const f = document.getElementById('obra-formato').value;
            const g = document.getElementById('obra-genero').value;
            const s = document.getElementById('obra-sinopsis').value;
            const port = document.getElementById('pre-portada').src;

            if(!t) return window.showToast("Título vacío", false);
            
            window.manhwas.unshift({
                title: t, format: f, tag: g, sinopsis: s, numCh: 0, img: port.includes('base64') ? port : mockImg("1503758069677"), chapters: []
            });
            
            window.showToast("Obra creada");
            window.showSection('home');
        };

        window.handleSubirCapitulo = function() {
            const idx = document.getElementById('cap-obra-select').value;
            const num = parseInt(document.getElementById('cap-numero').value);
            if(isNaN(num) || idx === "") return window.showToast("Datos incompletos", false);
            
            const obra = window.manhwas[idx];
            if(obra.format === 'Anime') {
                const url = document.getElementById('cap-video-url').value;
                const file = document.getElementById('in-video').files[0];
                if(!url && !file) return window.showToast("Sube un video", false);
                const vidSrc = file ? URL.createObjectURL(file) : url;
                obra.chapters.push({ num, video: vidSrc });
            } else {
                const files = document.getElementById('in-paginas').files;
                if(files.length === 0) return window.showToast("Sube imágenes", false);
                const imgs = Array.from(files).map(f => URL.createObjectURL(f));
                obra.chapters.push({ num, pages: imgs });
            }
            obra.numCh = Math.max(obra.numCh, num);
            window.showToast("Capítulo publicado");
            window.showSection('home');
        };

        window.updateVideoName = function(input) {
            document.getElementById('video-status').innerText = input.files[0].name;
            document.getElementById('video-status').classList.add('text-blue-400');
        };

        window.updateFilesCount = function(input) {
            document.getElementById('paginas-status').innerText = `${input.files.length} imágenes`;
            document.getElementById('paginas-status').classList.add('text-blue-400');
        };

        window.previewImg = function(input, imgId, icoId) {
            if (input.files && input.files[0]) {
                const r = new FileReader();
                r.onload = (e) => {
                    const img = document.getElementById(imgId);
                    img.src = e.target.result;
                    img.classList.remove('hidden');
                    document.getElementById(icoId).classList.add('opacity-0');
                };
                r.readAsDataURL(input.files[0]);
            }
        };

        // --- AUTH SIMULATION ---
        window.openAuthModal = () => {
            const m = document.getElementById('auth-modal');
            m.classList.remove('hidden');
            setTimeout(() => m.classList.remove('opacity-0'), 10);
        };
        window.closeAuthModal = () => document.getElementById('auth-modal').classList.add('hidden');
        window.toggleAuthView = (v) => {
            document.getElementById('auth-login-view').classList.toggle('hidden', v === 'signup');
            document.getElementById('auth-signup-view').classList.toggle('hidden', v === 'login');
        };
        window.handleLoginAction = () => {
            document.getElementById('user-name-nav').innerText = "Usuario";
            document.getElementById('nav-profile').classList.remove('hidden');
            window.closeAuthModal();
            window.showToast("Sesión iniciada");
        };

        window.onload = () => window.render('home-grid', window.manhwas.slice(0, 6));

    </script>
</body>
</html>